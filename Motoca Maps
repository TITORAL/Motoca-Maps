# 1. Inicializa o Git na pasta do teu projeto
git init

# 2. Cria o arquivo principal de código (caso ainda não o tenhas feito)
# Garante que o código unificado do Flutter está salvo em: lib/main.dart

# 3. Adiciona todos os arquivos do projeto para serem salvos
git add .

# 4. Faz o teu primeiro salvamento interno (Commit)
git commit -m "Commit Inicial: App Unificado Motoca Maps"

# 5. Cria o ramo principal chamado 'main'
git branch -M main

# 6. Vincula o teu terminal ao repositório que criaste no site do GitHub
# (Substitui o link abaixo pelo link exato que o GitHub gerou para ti)
git remote add origin https://github.com/TEU_USUARIO_DO_GITHUB/motoca-maps.git

# 7. Sobe o código definitivamente para o GitHub
git push -u origin main
